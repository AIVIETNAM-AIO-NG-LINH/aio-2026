# Patterns tính theo build context (repo root). File này được BuildKit tự nhận
# vì nằm cạnh Dockerfile với tên <Dockerfile>.dockerignore.
.git
.gitignore
docker/

# Secrets — injected at runtime, never baked into the image
.env

# Python caches / local artifacts
__pycache__/
*.py[cod]
.venv/
venv/
env/
staticfiles/
media/
*.sqlite3
*.log

# Editors / OS
.idea/
.vscode/
.DS_Store
README.md
