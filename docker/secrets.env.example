# =============================================================================
# 🔐 SECRET của ai-aio — docker nạp qua env_file (xem docker-compose*.yml).
# Copy thành secrets.env rồi điền giá trị thật:  cp secrets.env.example secrets.env
# secrets.env đã được .gitignore — KHÔNG commit.
#
# Định dạng env_file của docker: KHÔNG để dấu " quanh giá trị.
# =============================================================================

# Django
DJANGO_SECRET_KEY=

# MariaDB — PHẢI KHỚP ../data-aio/.env và ../api-aio/docker/secrets.env
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Service-to-service token — PHẢI GIỐNG api-aio
INTERNAL_TOKEN=

# S3 / object storage (pipeline RAG tải file gốc) — KHỚP api-aio
# ⚠ TRÊN EC2: ĐỂ TRỐNG 2 key dưới — boto3 tự lấy credential qua IAM role của EC2
#   (default credential chain). CHỈ điền khi chạy LOCAL ngoài AWS.
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_ENDPOINT=
AWS_S3_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_S3_USE_PATH_STYLE=false
# Thư mục gốc chứa media trên bucket — KHỚP AWS_ROOT của api-aio
MEDIA_FOLDER=media
# Base URL công khai dựng link tải file gốc; bỏ trống → tự suy
AWS_S3_URL=

# Google GenAI / Gemini (extract + embedding + chat) — BẮT BUỘC cho RAG/chat
GEMINI_API_KEY=

# OpenSearch (nếu cluster bật security — dev để trống)
OPENSEARCH_PASSWORD=

# Reranker HTTP (nếu endpoint yêu cầu Bearer token — để trống nếu không)
RERANK_API_KEY=

# LightRAG (chỉ khi LIGHTRAG_ENABLED=true) — KHỚP ../data-aio/.env
LIGHTRAG_PG_PASSWORD=
LIGHTRAG_NEO4J_PASSWORD=
