# Copy this file to `.env` and adjust values. `.env` is git-ignored.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# `.localhost` cho phép ai.localhost (qua reverse proxy nginx-aio); `ai-aio` là alias docker.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.localhost,ai-aio
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://ai.localhost:8000
DJANGO_TIME_ZONE=UTC

# --- Database (MariaDB dùng chung với api-aio) ---
# ai-aio nối THẲNG vào DB `api_ai` (nơi api-aio chứa media + chatbot_documents),
# cùng instance MariaDB ở stack nginx-aio. ai-aio CHỈ ghi DATA (insert/update/delete)
# lên các bảng dùng chung — KHÔNG tạo/sửa cấu trúc bảng của api-aio (model media &
# chatbot_documents để managed=False nên migrate bỏ qua chúng).
# => DB_USER phải có quyền DML (SELECT/INSERT/UPDATE/DELETE) trên DB `api_ai`,
#    và quyền DDL trên các bảng RIÊNG của ai-aio (django_migrations, example, auth_*…)
#    mà entrypoint sẽ `migrate` vào cùng DB này.
DB_ENGINE=django.db.backends.mysql
DB_NAME=api_ai
DB_USER=change-me-db-user
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password
DB_HOST=db
DB_PORT=3306

# --- Internal service-to-service (ai-aio ↔ api-aio qua reverse-proxy nginx:8080) ---
# Đặt 1 chuỗi random; PHẢI GIỐNG nhau ở api-aio và ai-aio.
INTERNAL_TOKEN=
INTERNAL_GATEWAY_URL=http://nginx-aio:8080

# --- Celery / Redis (worker nền cho ingest tài liệu chatbot) ---
# Redis dùng chung trong stack nginx-aio (trên aio-net). Đổi host/alias nếu khác.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Realtime (push tiến độ ingest xuống FE qua node-aio) ---
# Django PUBLISH event lên Redis; node-aio subscribe rồi đẩy ra WebSocket.
# Mặc định dùng chung Redis với Celery broker. Prefix PHẢI khớp CHANNEL_PREFIX
# của node-aio (mặc định "aio"), nếu không FE sẽ không nhận được.
REALTIME_REDIS_URL=redis://redis:6379/0
REALTIME_CHANNEL_PREFIX=aio

# --- S3 / object storage (PHASE 1 — pipeline RAG tải file gốc về để parse) ---
# Object key của file = f"{MEDIA_FOLDER}/{file_name}" (file_name lấy từ bảng media).
AWS_S3_ENDPOINT=
AWS_S3_REGION=
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
# true với MinIO / S3-compatible (path-style URL: endpoint/bucket/key).
AWS_S3_USE_PATH_STYLE=false
# Thư mục gốc chứa media trên bucket (prefix của object key).
# LƯU Ý: phải KHỚP `AWS_ROOT` của api-aio (nơi upload file) — vd api-aio dùng `aio`.
MEDIA_FOLDER=media
# Base URL công khai để dựng link tải file gốc (`Media.url`) cho chatbot trích nguồn.
# Đặt = `AWS_URL` của api-aio để link KHỚP TUYỆT ĐỐI (vd https://<bucket>.s3.<region>.amazonaws.com).
# Bỏ trống → tự suy: có AWS_S3_ENDPOINT → endpoint/bucket/key; còn lại → bucket+region (AWS).
AWS_S3_URL=

# --- Google GenAI / Gemini (PHASE 1 — extract text + sinh embedding) ---
GEMINI_API_KEY=
# Model embedding. gemini-embedding-001 ở 768 chiều qua Matryoshka/MRL
# (output_dimensionality=768) — vector <3072 chiều KHÔNG normalize sẵn nên pipeline
# tự L2-normalize sau khi embed. Giữ OPENSEARCH_VECTOR_DIMS=768 cho khớp mapping.
# (text-embedding-004 đã EOL 14/01/2026.)
EMBEDDING_MODEL=gemini-embedding-001
# Model multimodal đọc PDF → text (mặc định gemini-2.5-flash).
GEMINI_EXTRACT_MODEL=gemini-2.5-flash

# --- Chunking (PHASE 1) ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Contextual chunk header (bản "light", KHÔNG gọi LLM mỗi chunk) ---
# Gắn 1 dòng metadata (tên tài liệu | trang | loại file) vào ĐẦU mỗi chunk trước
# khi embed → chunk tự đủ ngữ cảnh, tăng recall. Header vào cả vector lẫn
# chunk_text lưu ở OpenSearch; field `page` vẫn lưu riêng như cũ.
# Tắt (false) → quay về prefix cũ "File: {name}". Placeholder: {name} {page} {kind}.
CONTEXTUAL_HEADER_ENABLED=true
CONTEXTUAL_HEADER_FORMAT=Document: {name} | Page: {page} | Type: {kind}

# --- Trích dẫn theo trang (PHASE 4 — ingest) ---
# Trang PDF có ÍT HƠN ngưỡng ký tự này (sau strip) coi là trang scan/ảnh → OCR
# riêng trang đó bằng Gemini. Tăng nếu PDF có header/footer text-số gây nhiễu.
MIN_PAGE_TEXT_CHARS=20
# Trang có ảnh với data >= ngưỡng byte này cũng được OCR dù đã đủ text-số (trang
# "lai" — chữ trong ảnh/chart không bị mất). Ảnh nhỏ hơn coi là logo/trang trí.
# Đặt giá trị âm (vd -1) để tắt, quay về hành vi cũ: chỉ OCR trang scan.
MIN_OCR_IMAGE_BYTES=5000

# --- OpenSearch (PHASE 1 — index vector parent-child cho RAG) ---
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
# false để bỏ verify TLS (self-signed nội bộ); true khi có cert hợp lệ.
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX=rag-index
OPENSEARCH_VECTOR_DIMS=768

# --- Summary index (PHASE 2 — 1 doc tóm tắt + vector mỗi tài liệu) ---
# Model Gemini Flash sinh tóm tắt ≤200 ký tự (cũng dùng trích entity cho LightRAG).
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
# Index riêng chứa summary_text + summary_vector (knn 768). Tạo tự động nếu chưa có.
OPENSEARCH_SUMMARY_INDEX=document-summary-index

# --- Truy hồi / Retrieve (SERVICE QUERY — hybrid search + rerank, KHÔNG sinh LLM) ---
# Endpoint nội bộ POST /api/internal/v1/chatbot/retrieve. Mọi bước fail-safe.
# Số chunk trả về cuối cùng (sau rerank) và số ứng viên lấy từ hybrid để rerank.
RETRIEVE_TOP_K=5
RETRIEVE_TOP_N=30
# Hằng số Reciprocal Rank Fusion khi hợp nhất BM25 + kNN (lớn hơn = san phẳng thứ hạng).
RETRIEVE_RRF_K=60

# Query rewriting (Gemini Flash) — chuẩn hoá + dịch/mở rộng Việt<->Anh để tăng recall.
# Tắt (false) hoặc lỗi gọi LLM → chỉ dùng query gốc (fail-safe).
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_MODEL=gemini-2.5-flash
# Tổng số truy vấn (GỒM query gốc) đưa vào hybrid search — chặn chi phí.
QUERY_REWRITE_MAX_VARIANTS=3

# Reranker cross-encoder QUA HTTP (pluggable) — KHÔNG load model nặng trong Django.
# Tắt (false), thiếu RERANK_ENDPOINT_URL, hoặc lỗi/timeout → bỏ rerank, giữ thứ hạng
# hybrid (fail-safe). Endpoint nhận {model, query, documents:[...]} trả [{index, score}]
# hoặc {results:[{index, relevance_score}]} (TEI/BGE, Jina, Cohere-compatible).
RERANK_ENABLED=true
RERANK_ENDPOINT_URL=
RERANK_MODEL=bge-reranker-v2-m3
# Bearer token nếu endpoint yêu cầu (để trống nếu không).
RERANK_API_KEY=
RERANK_TIMEOUT=15
# Ngưỡng điểm liên quan (áp trên rerank_score, thang ~0..1 của cross-encoder). Chunk
# dưới ngưỡng bị loại; câu hỏi ngoài phạm vi tài liệu → không còn chunk đạt → bot trả
# lời "không có trong tài liệu" thay vì ghép từ nhiễu. 0 = tắt lọc. CHỈ áp khi rerank
# thực sự chạy. Cao hơn = chặt hơn (dễ từ chối), thấp hơn = thoáng hơn. Mặc định 0.3.
RERANK_SCORE_THRESHOLD=0.3

# Sàn điểm cosine kNN — CỔNG CHỐNG BỊA DỰ PHÒNG khi rerank KHÔNG chạy (tắt/thiếu
# endpoint/lỗi). Lúc đó RERANK_SCORE_THRESHOLD không áp được (không có rerank_score),
# nên dùng điểm cosine kNN (thang cosinesimil) làm cổng: chunk dưới sàn bị loại →
# câu hỏi ngoài phạm vi tài liệu trả [] → bot từ chối thay vì ghép từ nhiễu.
# 0 = tắt. Thang cosine của gemini-embedding-001 cho nội dung KHÔNG liên quan vẫn
# ~0.75–0.77 (không gần 0!), còn câu hỏi đúng phạm vi đạt ~0.84–0.91 — calibrate
# trên corpus thật (7 câu in-scope vs 5 out-scope) cho biên tách biệt ~0.072, nên
# 0.80 là sàn cân bằng (loại nhiễu, vẫn giữ câu hợp lệ). PHẢI hiệu chỉnh lại nếu đổi
# embedding model / corpus (xem log "knn_score" / "fallback sàn cosine"). Khi đã cấu
# hình RERANK_ENDPOINT_URL thì rerank chạy và sàn cosine này tự nhường chỗ cho rerank.
HYBRID_MIN_COSINE=0.80

# --- Chatbot: luồng chat (Google ADK: Agent + tool RAG + Runner SSE) ---
# Endpoint công khai POST /api/v1/chatbot/chat (SSE). Luồng chat chạy qua google-adk:
# agent tự gọi tool `search_knowledge_base` (bọc RAG retrieve ở trên) khi cần.
# ADK đọc API key từ GOOGLE_API_KEY — app tự map từ GEMINI_API_KEY nếu chưa set.
# Model Gemini cho agent (function-calling + stream). Mặc định tái dùng model ai-aio
# đã cấu hình sẵn (như extract/summary/rewrite). Đổi sang model khác (vd 'gemini-3-
# flash-preview' như ga-ai) nếu API key có quyền và muốn chất lượng cao hơn.
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Số chunk RAG tool trả về mặc định (agent có thể tự chỉnh top_k khi gọi tool).
CHAT_CONTEXT_TOP_K=5
# Số tin nhắn gần nhất (cả user + assistant) nạp làm lịch sử hội thoại.
CHAT_HISTORY_SIZE=10

# Tự sinh tiêu đề hội thoại từ lượt hỏi-đáp đầu (Celery, nền). Tắt → hội thoại không có title.
CHAT_TITLE_ENABLED=true
GEMINI_TITLE_MODEL=gemini-2.5-flash

# Long-term memory (LTM): index hội thoại cũ vào OpenSearch để truy hồi xuyên hội thoại.
# Tắt → bỏ qua hẳn LTM (luồng chat vẫn chạy bình thường). Index riêng, vector 768 chiều.
CHAT_LTM_ENABLED=true
OPENSEARCH_CHAT_HISTORY_INDEX=chatbot-chat-history
# Số lượt hội thoại cũ truy hồi + ngưỡng điểm tối thiểu để giữ (cosine, 0..1).
CHAT_LTM_TOP_K=3
CHAT_LTM_MIN_SCORE=0.5

# File user đính kèm trong chat: đẩy media (PDF/Word) lên Gemini Files API rồi hỏi
# đáp NATIVE trong phạm vi hội thoại đó (không index RAG). Tắt → bỏ qua media_ids.
CHAT_ATTACHED_FILES_ENABLED=true
# Trần số file đính kèm mỗi lượt (chống lạm dụng / quá context).
CHAT_ATTACHED_FILES_MAX=5
# TTL file trên Gemini Files API (giờ, ~48h) — quá hạn thì tự đẩy lại khi cần.
GEMINI_FILE_TTL_HOURS=48

# --- LibreOffice (PHASE 2 — convert Word .doc/.docx → PDF trong worker) ---
# Binary headless; đổi nếu image cài tên khác (vd 'libreoffice').
LIBREOFFICE_BIN=soffice
# Timeout (giây) cho 1 lần convert, tránh treo worker.
LIBREOFFICE_TIMEOUT=120

# --- LightRAG / Knowledge graph (PHASE 2 — fail-safe, TẮT mặc định) ---
# false: bỏ qua hẳn KG (an toàn khi chưa dựng PostgreSQL/Neo4j). Bật khi đã có hạ tầng.
LIGHTRAG_ENABLED=false
# PostgreSQL (pgvector) cho KV/Vector/DocStatus storage của LightRAG.
LIGHTRAG_PG_HOST=postgres
LIGHTRAG_PG_PORT=5432
LIGHTRAG_PG_USER=postgres
LIGHTRAG_PG_PASSWORD=
LIGHTRAG_PG_DATABASE=lightrag
# Neo4j cho graph storage.
LIGHTRAG_NEO4J_URI=bolt://neo4j:7687
LIGHTRAG_NEO4J_USERNAME=neo4j
LIGHTRAG_NEO4J_PASSWORD=
