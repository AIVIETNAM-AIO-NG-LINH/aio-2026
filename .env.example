# Copy this file to `.env` and adjust values. `.env` is git-ignored.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# `.localhost` cho phép ai.localhost (qua reverse proxy nginx-aio); `ai-aio` là alias docker.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.localhost,ai-aio
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://ai.localhost
DJANGO_TIME_ZONE=UTC

# --- Database (MariaDB dùng chung với api-aio) ---
# ai-aio nối THẲNG vào DB `api_ai` (nơi api-aio chứa media + chatbot_documents),
# cùng instance MariaDB ở stack nginx-aio. ai-aio CHỈ ghi DATA (insert/update/delete)
# lên các bảng dùng chung — KHÔNG tạo/sửa cấu trúc bảng của api-aio (model media &
# chatbot_documents để managed=False nên migrate bỏ qua chúng).
# => DB_USER phải có quyền DML (SELECT/INSERT/UPDATE/DELETE) trên DB `api_ai`,
#    và quyền DDL trên các bảng RIÊNG của ai-aio (django_migrations, example, auth_*…)
#    mà entrypoint sẽ `migrate` vào cùng DB này.
DB_ENGINE=django.db.backends.mysql
DB_NAME=api_ai
DB_USER=change-me-db-user
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password
DB_HOST=db
DB_PORT=3306

# --- Internal service-to-service (ai-aio ↔ api-aio qua reverse-proxy nginx:8080) ---
# Đặt 1 chuỗi random; PHẢI GIỐNG nhau ở api-aio và ai-aio.
INTERNAL_TOKEN=
INTERNAL_GATEWAY_URL=http://nginx-aio:8080

# --- Celery / Redis (worker nền cho ingest tài liệu chatbot) ---
# Redis dùng chung trong stack nginx-aio (trên aio-net). Đổi host/alias nếu khác.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- S3 / object storage (PHASE 1 — pipeline RAG tải file gốc về để parse) ---
# Object key của file = f"{MEDIA_FOLDER}/{file_name}" (file_name lấy từ bảng media).
AWS_S3_ENDPOINT=
AWS_S3_REGION=
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
# true với MinIO / S3-compatible (path-style URL: endpoint/bucket/key).
AWS_S3_USE_PATH_STYLE=false
# Thư mục gốc chứa media trên bucket (prefix của object key).
MEDIA_FOLDER=media

# --- Google GenAI / Gemini (PHASE 1 — extract text + sinh embedding) ---
GEMINI_API_KEY=
# Model embedding. gemini-embedding-001 ở 768 chiều qua Matryoshka/MRL
# (output_dimensionality=768) — vector <3072 chiều KHÔNG normalize sẵn nên pipeline
# tự L2-normalize sau khi embed. Giữ OPENSEARCH_VECTOR_DIMS=768 cho khớp mapping.
# (text-embedding-004 đã EOL 14/01/2026.)
EMBEDDING_MODEL=gemini-embedding-001
# Model multimodal đọc PDF → text (mặc định gemini-2.5-flash).
GEMINI_EXTRACT_MODEL=gemini-2.5-flash

# --- Chunking (PHASE 1) ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Trích dẫn theo trang (PHASE 4 — ingest) ---
# Trang PDF có ÍT HƠN ngưỡng ký tự này (sau strip) coi là trang scan/ảnh → OCR
# riêng trang đó bằng Gemini. Tăng nếu PDF có header/footer text-số gây nhiễu.
MIN_PAGE_TEXT_CHARS=20

# --- OpenSearch (PHASE 1 — index vector parent-child cho RAG) ---
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
# false để bỏ verify TLS (self-signed nội bộ); true khi có cert hợp lệ.
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX=rag-index
OPENSEARCH_VECTOR_DIMS=768

# --- Summary index (PHASE 2 — 1 doc tóm tắt + vector mỗi tài liệu) ---
# Model Gemini Flash sinh tóm tắt ≤200 ký tự (cũng dùng trích entity cho LightRAG).
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
# Index riêng chứa summary_text + summary_vector (knn 768). Tạo tự động nếu chưa có.
OPENSEARCH_SUMMARY_INDEX=document-summary-index

# --- LibreOffice (PHASE 2 — convert Word .doc/.docx → PDF trong worker) ---
# Binary headless; đổi nếu image cài tên khác (vd 'libreoffice').
LIBREOFFICE_BIN=soffice
# Timeout (giây) cho 1 lần convert, tránh treo worker.
LIBREOFFICE_TIMEOUT=120

# --- LightRAG / Knowledge graph (PHASE 2 — fail-safe, TẮT mặc định) ---
# false: bỏ qua hẳn KG (an toàn khi chưa dựng PostgreSQL/Neo4j). Bật khi đã có hạ tầng.
LIGHTRAG_ENABLED=false
# PostgreSQL (pgvector) cho KV/Vector/DocStatus storage của LightRAG.
LIGHTRAG_PG_HOST=postgres
LIGHTRAG_PG_PORT=5432
LIGHTRAG_PG_USER=postgres
LIGHTRAG_PG_PASSWORD=
LIGHTRAG_PG_DATABASE=lightrag
# Neo4j cho graph storage.
LIGHTRAG_NEO4J_URI=bolt://neo4j:7687
LIGHTRAG_NEO4J_USERNAME=neo4j
LIGHTRAG_NEO4J_PASSWORD=
